{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"]
    },
    "logs": {
        "text": "php://stderr",
        "summary": "build/infection-summary.log"
    },
    "testFramework": "testo",
    // 5 surviving mutants are equivalent ReturnRemoval on defensive fallback
    // guards (FileMaintenanceProvider file/JSON/array early returns and
    // MaintenanceMiddleware empty-allow-list / empty-hash guards): the
    // subsequent guard produces the same result, so no test can kill them.
    "minMsi": 92,
    "mutators": {
        "@default": true
    }
}
